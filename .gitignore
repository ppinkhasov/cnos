# dependencies (regenerated by `npm install`)
node_modules/

# whisper.cpp models — large binaries; downloaded via the README
models/
*.bin

# local Claude Code settings (machine-specific)
.claude/settings.local.json

# orchestrator scratch — the lead agent's directive channel, written at runtime
# into the agents' working dir (only appears here if CNOS_WORKDIR is the repo)
.cnos/

# logs / OS / editor cruft
*.log
npm-debug.log*
.DS_Store
.idea/
.vscode/
